# Ericsson NCM API Keys (v2)
CP_API_ID=your_cp_api_id
CP_API_KEY=your_cp_api_key
ECM_API_ID=your_ecm_api_id
ECM_API_KEY=your_ecm_api_key

# Ericsson NCM v3 Bearer Token
V3_BEARER_TOKEN=your_v3_bearer_token

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/license_renewal

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Logging
LOG_LEVEL=INFO

# Auto-assignment Configuration
AUTO_ASSIGNMENT_ENABLED=true
EXPIRATION_WARNING_DAYS=30
UNASSIGNED_REMINDER_DAYS=7

# Audit Configuration
AUDIT_RETENTION_YEARS=7
